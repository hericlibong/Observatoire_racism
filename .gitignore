# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.codex

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Notebooks
.ipynb_checkpoints/

# Logs
logs/
*.log

# Local build / temp outputs
tmp/
.tmp/
dist/
build/

# Data outputs generated during work
data/interim/

# Ignore all exports by default
data/exports/*

# Keep the D3 pilot artifacts versioned.
# The pattern is deliberately stable so that new sessions are versioned
# without having to append one exception per seance.
!data/exports/d3/
data/exports/d3/*
!data/exports/d3/assemblee_pilot_timeline.html
!data/exports/d3/assemblee_pilot_timeline.json
!data/exports/d3/assemblee_session_heatmap_n*.html
!data/exports/d3/assemblee_session_heatmap_n*.json
!data/exports/d3/assemblee_sessions_overview.html
!data/exports/d3/assemblee_sessions_overview.json

# Coverage
.coverage
htmlcov/

# Environnement
.env
.env.*
!.env.example

# Python version manager
.python-version
