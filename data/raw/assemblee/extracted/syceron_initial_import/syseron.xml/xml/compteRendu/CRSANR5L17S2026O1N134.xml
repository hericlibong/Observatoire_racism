    <point nivpoint="1" valeur_ptsodj="1" ordinal_prise="1" id_preparation="2863107" ordre_absolu_seance="12" code_grammaire="TITRE_TEXTE_DISCUSSION" code_style="Titre" code_parole="" sommaire="1" id_syceron="4005615" valeur=" (n[[o]] 2410)">
